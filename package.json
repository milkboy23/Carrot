{
  "name": "carrot",
  "publisher": "EmmaAndrea",
  "displayName": "Carrot Comments Extension",
  "description": "",
  "version": "1.0.0",
  "icon": "media/images/carrot-decoration.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/milkboy23/Carrot"
  },  
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView: carrot-sidebar-view"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "carrot-sidebar-view",
          "title": "Carrot",
          "icon": "media/images/carrot-icon.png"
        }
      ]
    },
    "views": {
      "carrot-sidebar-view": [
        {
          "type": "webview",
          "id": "carrot-sidebar",
          "name": "Carrot",
          "icon": "media/images/carrot-icon.png",
          "contextualTitle": "Carrot"
        }
      ]
    },
    "commands": [
      {
        "command": "carrot.createCarrot",
        "category": "Carrot",
        "title": "Create New Carrot Comment"
      },
      {
        "command": "carrot.deleteCarrot",
        "category": "Carrot",
        "title": "Delete Selected Carrot Comment"
      },
      {
        "command": "carrot.commentAndNote",
        "category": "Carrot",
        "title": "Create new Carrot Comment with Note"
      },
      {
        "command": "carrot.openNote",
        "category": "Carrot",
        "title": "Open Carrot Note"
      }
    ],
    "keybindings": [
      {
        "command": "carrot.createCarrot",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editor.hasSelection"
      },
      {
        "command": "carrot.deleteCarrot",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+l",
        "when": "editor.hasSelection"
      },
      {
        "command": "carrot.commentAndNote",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editor.hasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build-webview": "node esbuild.js",
    "watch-webview": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "jodit": "^4.11.15",
    "react": "^19.2.4",
    "showdown": "^2.1.0"
  }
}
